{
  "name": "tripslip-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:property": "turbo run test:property",
    "test:integration": "turbo run test:integration",
    "test:smoke": "vitest run tests/smoke --reporter=verbose",
    "test:coverage": "vitest run --coverage",
    "check:coverage": "node scripts/check-coverage.js",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules",
    "verify:stripe": "tsx scripts/verify-stripe-setup.ts",
    "verify:database": "tsx scripts/verify-production-database.ts",
    "create-test-users": "tsx scripts/create-test-users.ts"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "1.6.1",
    "dotenv": "17.3.1",
    "fast-check": "3.23.2",
    "turbo": "2.8.12",
    "typescript": "~5.9.3",
    "vitest": "1.6.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "isomorphic-dompurify": "3.0.0"
  }
}
