# Supabase Configuration (Required for all apps)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe Configuration (Required for: Venue, Teacher, Parent apps)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-key
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-secret

# Email Service (SendGrid or Resend)
EMAIL_API_KEY=your-email-api-key
EMAIL_FROM=noreply@tripslip.com

# SMS Service (Twilio)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+15555551234

# Sentry Configuration (Optional for all apps)
VITE_SENTRY_DSN=https://your-dsn@sentry.io/project-id
SENTRY_AUTH_TOKEN=your-auth-token
SENTRY_ORG=tripslip
SENTRY_PROJECT=tripslip

# Google Maps API (Optional for: Venue, Teacher apps)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Google Analytics (Optional for: Landing app)
VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Application URLs (Required for each app)
VITE_LANDING_APP_URL=https://tripslip.com
VITE_VENUE_APP_URL=https://venue.tripslip.com
VITE_SCHOOL_APP_URL=https://school.tripslip.com
VITE_TEACHER_APP_URL=https://teacher.tripslip.com
VITE_PARENT_APP_URL=https://parent.tripslip.com

# Environment
NODE_ENV=development
VITE_ENVIRONMENT=development

# Vercel (for CI/CD)
VERCEL_TOKEN=your-vercel-token
VERCEL_ORG_ID=your-org-id
VERCEL_PROJECT_ID=your-project-id

# Codecov (for coverage reporting)
CODECOV_TOKEN=your-codecov-token
