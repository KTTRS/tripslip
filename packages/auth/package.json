{
  "name": "@tripslip/auth",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "lint": "eslint .",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --testNamePattern=\"^((?!Property|Integration).)*$\"",
    "test:property": "vitest run --testNamePattern=\"Property\"",
    "test:integration": "vitest run --testNamePattern=\"Integration\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.97.0",
    "@tripslip/database": "file:../database",
    "@tripslip/ui": "file:../ui",
    "react": "^18.3.1",
    "react-router": "^7.1.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@vitest/ui": "2.1.9",
    "fast-check": "3.23.2",
    "jsdom": "25.0.1",
    "typescript": "~5.9.3",
    "vitest": "2.1.9"
  }
}
